# Path to your oh-my-zsh installation.
export ZSH="$HOME/.oh-my-zsh"

# Set name of the theme to load.
ZSH_THEME="robbyrussell"

# Disable bi-weekly auto-update checks.
DISABLE_AUTO_UPDATE="true"

# Command auto-correction.
ENABLE_CORRECTION="true"

plugins=(git common-aliases github python sudo)

ZSH_CACHE_DIR=$HOME/.oh-my-zsh-cache
if [[ ! -d $ZSH_CACHE_DIR ]]; then
  mkdir $ZSH_CACHE_DIR
fi

source $ZSH/oh-my-zsh.sh

# --- environment ---
export PATH=$HOME/bin:$HOME/.local/bin:/opt/homebrew/bin:/usr/local/bin:$PATH
export PATH="/opt/homebrew/opt/openjdk@21/bin:$PATH"
export LANG=en_US.UTF-8

# vim everywhere (was 'nvim' locally, but neovim isn't installed on this box)
export EDITOR='vim'

# https://serebrov.github.io/html/2014-01-04-git-log-and-less-keep-output.html
export LESS=-iXFR

unsetopt share_history

# --- openclaw completions (present on some machines only) ---
[[ -f "$HOME/.openclaw/completions/openclaw.zsh" ]] && source "$HOME/.openclaw/completions/openclaw.zsh"

# --- machine-local overrides: API keys, work aliases, per-host PATHs ---
# NEVER commit ~/.zshrc.local — it holds secrets and is intentionally untracked.
[[ -f "$HOME/.zshrc.local" ]] && source "$HOME/.zshrc.local"

# --- fs nav: zoxide (`z <name>`) + fzf (Ctrl-T / Alt-C / Ctrl-R) ---
eval "$(zoxide init zsh)"
eval "$(fzf --zsh)"
# --- end fs nav ---

# --- ranger: cd shell to wherever you navigate ---
function rcd {
    local tmp="$(mktemp)"
    ranger --choosedir="$tmp" -- "${@:-$PWD}"
    if [ -f "$tmp" ]; then
        local dir="$(cat "$tmp")"
        rm -f "$tmp"
        [ -d "$dir" ] && [ "$dir" != "$PWD" ] && cd -- "$dir"
    fi
}
# --- end ranger cd ---
